# Example environment variables for Conductor
# Copy this file to .env and fill in your values

# JIRA Integration (Optional)
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_SERVER_URL=https://your-company.atlassian.net
JIRA_USERNAME=your_email@company.com

# Confluence Integration (Optional)
CONFLUENCE_API_TOKEN=your_confluence_api_token_here
CONFLUENCE_SERVER_URL=https://your-company.atlassian.net

# GitHub Integration (Optional)
GITHUB_TOKEN=your_github_token_here

# Slack Integration (Optional)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Webex Integration (Optional)
WEBEX_BOT_TOKEN=your_webex_bot_token_here

# Note: All integrations are optional. Conductor works fully offline
# and will gracefully handle missing configurations.